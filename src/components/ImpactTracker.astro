---
import { impactStats } from '../data/home';
---

<section id="impact" data-impact-section class="home-impact relative overflow-hidden border-y-2 border-ink bg-paper px-6 py-24 text-ink md:px-10 lg:px-20">
  <div class="home-impact-leaf" aria-hidden="true"></div>
  <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="mb-4 w-fit -rotate-2 rounded-2xl bg-bcorp-green px-4 py-2 text-xs font-black uppercase tracking-wide text-cream">Impact for good</p>
      <h2 class="font-serif text-5xl leading-none text-ink md:text-7xl">Certified care, measured properly.</h2>
      <p class="mt-7 max-w-xl text-base font-bold leading-8 text-cocoa">
        Change Hospitality's B-Corp certification reflects a recruitment model that values people, community and long-term responsibility alongside commercial performance.
      </p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {impactStats.map((stat) => (
        <article class="home-impact-stat rounded-[1.7rem] border-2 border-bcorp-green bg-cream p-6">
          <p class="font-serif text-5xl leading-none text-bcorp-green md:text-6xl">
            <span data-count data-target={stat.target} data-decimals={stat.decimals}>0</span>{stat.suffix}
          </p>
          <p class="mt-4 text-sm font-black uppercase text-bcorp-green">{stat.label}</p>
        </article>
      ))}
    </div>
  </div>
  <div class="mx-auto mt-14 grid max-w-7xl gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
    <div class="flex items-center gap-5 rounded-[1.7rem] border-2 border-bcorp-green bg-bcorp-green/10 p-6">
      <svg class="h-24 w-24 shrink-0 text-bcorp-green" viewBox="0 0 120 120" fill="none" aria-hidden="true">
        <circle data-draw-path cx="60" cy="60" r="45" stroke="currentColor" stroke-width="2"></circle>
        <path data-draw-path d="M60 86V44M42 64C42 53 50 44 60 44C70 44 78 53 78 64C78 75 70 84 60 84C50 84 42 75 42 64Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        <path data-draw-path d="M49 58C56 58 61 54 64 48M71 63C65 63 61 59 58 52" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <div>
        <p class="text-sm font-black uppercase text-bcorp-green">B-Corp verified</p>
        <p class="mt-2 text-sm font-bold leading-7 text-bcorp-green">Ethical recruitment, transparent standards and a measurable commitment to doing better business.</p>
      </div>
    </div>
    <p class="font-serif text-3xl leading-tight text-ink md:text-4xl">
      The same care applied to a candidate conversation should show up in the way the business treats communities, suppliers and the planet.
    </p>
  </div>
</section>

<style>
  .home-impact-leaf {
    position: absolute;
    right: -8rem;
    bottom: -8rem;
    height: 20rem;
    width: 28rem;
    border-radius: 65% 35% 58% 42% / 52% 38% 62% 48%;
    background: color-mix(in srgb, var(--color-bcorp-green) 20%, var(--color-paper));
    transform: rotate(-18deg);
  }

  .home-impact-stat:nth-child(2) {
    transform: rotate(1.5deg);
  }

  .home-impact-stat:nth-child(3) {
    transform: rotate(-1.5deg);
  }

  .home-impact-stat > p:first-child {
    min-width: 0;
    font-size: clamp(2.2rem, 3.2vw, 3.35rem);
    white-space: nowrap;
  }

  .home-impact-stat:nth-child(2) > p:first-child {
    font-size: clamp(1.85rem, 2.35vw, 2.5rem);
  }
</style>