---
import { divisions } from '../data/home';
---

<section id="divisions" data-division-section class="relative bg-obsidian lg:h-[300vh]">
  <div class="flex w-full flex-col overflow-hidden bg-obsidian lg:sticky lg:top-0 lg:h-screen lg:flex-row">
    <div class="relative z-10 flex flex-col justify-center border-b border-off-white/10 px-6 py-16 md:px-10 lg:min-h-0 lg:w-[45%] lg:border-b-0 lg:border-r lg:px-20">
      <p class="mb-5 text-sm font-semibold uppercase text-champagne">Specialist divisions</p>
      <div class="space-y-7">
        {divisions.map((division, index) => (
          <article data-division-copy class:list={[
            'origin-left transition-colors duration-500',
            index === 0 ? 'text-off-white' : 'text-off-white/42',
          ]}>
            <p class="mb-2 text-xs font-semibold uppercase text-champagne/80">0{index + 1} / {division.label}</p>
            <h2 class="font-serif text-4xl leading-none md:text-5xl">{division.name}</h2>
            <p class="mt-4 max-w-xl text-sm leading-7 text-off-white/70 md:text-base">{division.description}</p>
            <ul class="mt-5 flex flex-wrap gap-2" aria-label={`${division.name} specialisms`}>
              {division.details.map((detail) => <li class="rounded-full border border-off-white/12 px-3 py-1 text-xs text-off-white/70">{detail}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
    <div class="grid gap-3 px-6 pb-16 md:px-10 lg:relative lg:min-h-0 lg:flex-1 lg:overflow-hidden lg:p-0" aria-label="Division imagery">
      {divisions.map((division, index) => (
        <figure data-division-image class="relative h-72 overflow-hidden rounded-lg md:h-96 lg:absolute lg:inset-0 lg:h-auto lg:rounded-none" style={`z-index: ${index + 1};`}>
          <img class="h-full w-full object-cover" src={division.image} alt={division.alt} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
          <figcaption class="absolute bottom-6 left-6 rounded-lg border border-off-white/14 bg-obsidian/70 px-4 py-3 text-sm text-off-white backdrop-blur md:bottom-10 md:left-10">
            {division.name}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>