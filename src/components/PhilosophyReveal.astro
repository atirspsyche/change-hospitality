---
import { philosophy } from '../data/home';

const words = philosophy.split(' ');
---

<section id="approach" data-philosophy class="home-philosophy relative isolate flex min-h-screen w-full items-center justify-center overflow-hidden bg-cream px-6 py-24 text-ink md:px-24">
  <div class="home-philosophy-shape home-philosophy-shape-one" aria-hidden="true"></div>
  <div class="home-philosophy-shape home-philosophy-shape-two" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto max-w-6xl text-center">
    <p class="mx-auto mb-8 w-fit -rotate-2 rounded-2xl bg-citron px-5 py-3 text-xs font-black uppercase tracking-wide text-ink">
      Our recipe / people first
    </p>
    <p class="font-serif text-3xl leading-tight text-ink md:text-5xl md:leading-tight">
      {words.map((word) => <span class="reveal-word inline-block opacity-15">{word}&nbsp;</span>)}
    </p>
  </div>
</section>

<style>
  .home-philosophy-shape {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
  }

  .home-philosophy-shape-one {
    top: 5%;
    right: -13rem;
    height: 17rem;
    width: 33rem;
    background: var(--color-blush);
    transform: rotate(-10deg);
  }

  .home-philosophy-shape-two {
    bottom: 6%;
    left: -11rem;
    height: 13rem;
    width: 28rem;
    background: var(--color-mint);
    transform: rotate(8deg);
  }
</style>