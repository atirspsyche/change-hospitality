---
import { opportunities } from '../data/home';
---

<section id="opportunities" class="overflow-hidden bg-obsidian py-24 pl-6 text-off-white md:pl-10 lg:pl-20">
  <div class="mb-10 flex max-w-7xl flex-col gap-5 pr-6 md:flex-row md:items-end md:justify-between md:pr-10 lg:pr-20">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase text-champagne">Live opportunities</p>
      <h2 class="font-serif text-5xl leading-none md:text-7xl">Roles with momentum.</h2>
    </div>
    <a class="luxury-button inline-flex min-h-12 items-center justify-center rounded-lg px-6 text-sm font-semibold uppercase text-off-white" href="#apply">Register interest</a>
  </div>
  <div data-job-carousel class="relative" tabindex="0" aria-label="Draggable opportunities carousel">
    <div data-drag-cursor class="pointer-events-none fixed left-0 top-0 z-50 hidden -translate-x-1/2 -translate-y-1/2 rounded-full bg-champagne px-5 py-4 text-xs font-semibold uppercase text-obsidian shadow-champagne">
      Drag to Explore
    </div>
    <div data-job-track class="job-scrollbar flex snap-x gap-5 overflow-x-auto pb-8 pr-6 md:gap-6 md:pr-10 lg:pr-20" role="list">
      {opportunities.map((job) => (
        <article class="job-card relative flex min-h-80 w-[82vw] shrink-0 snap-start flex-col justify-between overflow-hidden rounded-lg border border-off-white/10 bg-off-white/[0.04] p-6 transition-transform duration-500 ease-out md:w-[390px]" role="listitem">
          <div class="relative z-10">
            <p class="mb-4 text-sm font-semibold uppercase text-champagne transition-colors">{job.division}</p>
            <h3 class="font-serif text-4xl leading-none text-off-white transition-colors">{job.role}</h3>
          </div>
          <dl class="relative z-10 grid gap-4 text-sm text-off-white/76 transition-colors">
            <div class="flex justify-between gap-5 border-t border-current/15 pt-4"><dt>Location</dt><dd>{job.location}</dd></div>
            <div class="flex justify-between gap-5 border-t border-current/15 pt-4"><dt>Salary</dt><dd>{job.salary}</dd></div>
            <div class="flex justify-between gap-5 border-t border-current/15 pt-4"><dt>Type</dt><dd>{job.type}</dd></div>
          </dl>
          <a
            href="#apply"
            data-job-apply
            data-job-role={job.role}
            class="relative z-10 mt-7 inline-flex min-h-11 items-center justify-center rounded-lg border border-current px-4 text-sm font-semibold uppercase transition-colors"
          >
            Apply now
          </a>
        </article>
      ))}
    </div>
  </div>
</section>