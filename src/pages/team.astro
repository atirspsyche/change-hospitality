---
import CircularGallery from "../components/team/CircularGallery";
import ProfileCard from "../components/team/ProfileCard";
import FunMenu from "../components/FunMenu.astro";
import { teamGalleryItems, teamMembers, teamPassSteps } from "../data/team";
import BaseLayout from "../layouts/BaseLayout.astro";

const footerLinks = [
  { label: "Team", href: "#profiles", note: "Meet the room" },
  { label: "Process", href: "#pass", note: "How roles move" },
  { label: "Jobs", href: "/portal/", note: "Open opportunities" },
  { label: "Home", href: "/", note: "Back to the start" },
];

const socialLinks = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/change-hospitality/",
  },
  { label: "Instagram", href: "https://www.instagram.com/changehospitality/" },
  { label: "Email", href: "mailto:hello@changehospitality.co.uk" },
];
---

<BaseLayout
  title="Team Profiles | Change Hospitality"
  description="Meet the Change Hospitality team: people-first consultants for front of house, back of house, events and commercial hospitality recruitment."
  image="https://images.unsplash.com/photo-1559329007-40df8a9345d8?auto=format&fit=crop&w=1600&q=85"
>
  <FunMenu />

  <main
    class="team-page min-h-screen overflow-hidden bg-paper text-ink"
    data-team-page
  >
    <section
      class="team-hero relative isolate min-h-screen overflow-hidden bg-cream px-5 pb-14 pt-28 md:px-10 md:pt-32"
      aria-labelledby="team-title"
    >
      <div
        class="team-cloud team-cloud-1"
        data-parallax="18"
        aria-hidden="true"
      >
      </div>
      <div
        class="team-cloud team-cloud-2"
        data-parallax="-26"
        aria-hidden="true"
      >
      </div>
      <div
        class="team-hero-oval team-hero-oval-1"
        data-parallax="56"
        aria-hidden="true"
      >
      </div>
      <div
        class="team-hero-oval team-hero-oval-2"
        data-parallax="-42"
        aria-hidden="true"
      >
      </div>

      <div
        class="relative z-10 mx-auto grid max-w-7xl gap-12 pt-6 md:pt-10 lg:min-h-[calc(100vh-9rem)] lg:grid-cols-[0.95fr_1.05fr] lg:items-center"
      >
        <div class="relative z-20 max-w-4xl">
          <p
            class="mb-6 w-fit -rotate-2 rounded-[1.35rem] bg-citron px-6 py-3 text-sm font-black uppercase tracking-wide text-ink"
          >
            Team profiles / service pass
          </p>
          <h1
            id="team-title"
            class="font-serif text-6xl font-semibold leading-[0.92] text-ink md:text-8xl lg:text-9xl"
          >
            Meet the people who make the handoff.
          </h1>
          <p
            class="mt-7 max-w-xl text-xl font-black leading-8 text-cocoa md:text-2xl md:leading-9"
          >
            A placement is not a click. It is cracked, checked, cooked, flipped
            and served by people who know hospitality from the inside.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a class="team-hero-button bg-flame text-cream" href="#profiles"
              >Meet the consultants</a
            >
            <a class="team-hero-button bg-mint text-ink" href="#gallery"
              >See the storyboard</a
            >
          </div>
        </div>

        <div
          class="team-pass-stage relative min-h-144 lg:min-h-176"
          aria-label="Animated team service pass illustration"
        >
          <div class="team-plate" data-parallax="10" aria-hidden="true">
            <div class="team-egg-white"><span class="team-yolk"></span></div>
            <div class="team-plate-note">Every role has a recipe.</div>
          </div>

          <div class="team-pass-ticket team-pass-ticket-one">
            <span>Listen</span>
            <strong>Brief taken</strong>
          </div>
          <div class="team-pass-ticket team-pass-ticket-two">
            <span>Read</span>
            <strong>Talent checked</strong>
          </div>
          <div class="team-pass-ticket team-pass-ticket-three">
            <span>Serve</span>
            <strong>Intro landed</strong>
          </div>

          {
            teamMembers.map((member, index) => (
              <div class={`team-orbit-card team-orbit-${index + 1}`}>
                <img src={member.miniAvatarUrl} alt="" loading="lazy" />
                <span>{member.division}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="profiles"
      class="team-profiles-section relative overflow-hidden px-5 py-18 md:px-10 md:py-24"
      aria-labelledby="profiles-title"
    >
      <div
        class="team-section-oval team-section-oval-one"
        data-parallax="-32"
        aria-hidden="true"
      >
      </div>
      <div
        class="team-section-oval team-section-oval-two"
        data-parallax="24"
        aria-hidden="true"
      >
      </div>
      <div class="relative z-10 mx-auto max-w-7xl">
        <div
          class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end"
        >
          <div>
            <p
              class="mb-4 text-sm font-black uppercase tracking-wide text-flame"
            >
              Consultants
            </p>
            <h2
              id="profiles-title"
              class="font-serif text-5xl font-semibold leading-none text-ink md:text-7xl"
            >
              Cards with a pulse.
            </h2>
          </div>
          <p class="max-w-xl text-lg font-bold leading-8 text-cocoa">
            Hover the cards: they scoot, wobble and react like flat storyboard
            panels. Big blocks, loud colour, no gloss.
          </p>
        </div>

        <div class="team-card-grid grid gap-8 md:grid-cols-2">
          {
            teamMembers.map((member) => (
              <ProfileCard
                client:visible
                name={member.name}
                title={member.title}
                handle={member.handle}
                status={member.status}
                contactText={member.contactText}
                avatarUrl={member.avatarUrl}
                miniAvatarUrl={member.miniAvatarUrl}
                accent={member.accent}
                note={member.note}
                signal={member.signal}
                division={member.division}
                enableTilt={true}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="pass"
      class="team-pass-section relative overflow-hidden px-5 py-18 md:px-10 md:py-24 bg-flame"
      aria-labelledby="pass-title"
    >
      <div
        class="team-section-oval team-section-oval-three"
        data-parallax="38"
        aria-hidden="true"
      >
      </div>
      <div
        class="relative z-10 mx-auto grid max-w-7xl gap-6 lg:grid-cols-[0.7fr_1.3fr] lg:items-stretch"
      >
        <div
          class="team-process-poster rounded-[30px] bg-blush p-6 text-ink md:p-8"
          data-parallax="26"
        >
          <p class="mb-5 text-sm font-black uppercase tracking-wide">
            How the handoff works
          </p>
          <h2
            id="pass-title"
            class="font-serif text-5xl font-semibold leading-none md:text-6xl"
          >
            Not a database. A pass.
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {
            teamPassSteps.map((step) => (
              <article class="team-step-card rounded-[30px] bg-cream p-5 text-ink">
                <p class="text-sm font-black uppercase text-flame">
                  {step.label}
                </p>
                <p class="mt-6 text-xl font-semibold leading-7">{step.copy}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="gallery"
      class="relative overflow-hidden bg-cocoa py-18 md:py-24"
      aria-labelledby="gallery-title"
    >
      <div class="team-gallery-oval" data-parallax="34" aria-hidden="true">
      </div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10">
        <div class="mb-8 grid gap-6 lg:grid-cols-[0.85fr_1fr] lg:items-end">
          <div>
            <p
              class="mb-4 text-sm font-black uppercase tracking-wide text-citron"
            >
              Image gallery
            </p>
            <h2
              id="gallery-title"
              class="font-serif text-5xl font-semibold leading-none text-cream md:text-7xl"
            >
              A few frames of the work.
            </h2>
          </div>
          <p class="max-w-2xl text-lg font-bold leading-8 text-cream">
            Real photo frames for the people side of the work: briefing tables,
            service floors, kitchens and the human moments around every careful
            handoff.
          </p>
        </div>
      </div>

      <div class="relative z-10 h-136 md:h-168" aria-label="Storyboard gallery">
        <CircularGallery
          client:visible
          items={teamGalleryItems}
          bend={2.2}
          scrollEase={0.04}
          scrollSpeed={1.8}
          textColor="var(--color-cream)"
        />
      </div>
    </section>

    <footer
      class="team-footer relative isolate flex min-h-screen overflow-hidden px-5 py-20 text-ink md:px-10"
      aria-labelledby="team-footer-title"
    >
      <div
        class="team-footer-stamp team-footer-stamp-one"
        data-parallax="30"
        aria-hidden="true"
      >
        hi
      </div>
      <div
        class="team-footer-stamp team-footer-stamp-two"
        data-parallax="-24"
        aria-hidden="true"
      >
        jobs
      </div>
      <div class="team-footer-egg" data-parallax="18" aria-hidden="true">
        <span></span>
      </div>

      <div
        class="relative z-10 mx-auto grid w-full max-w-7xl gap-10 self-center lg:grid-cols-[1.05fr_0.95fr] lg:items-end"
      >
        <div>
          <p
            class="mb-6 w-fit rotate-2 rounded-[1.25rem] bg-flame px-5 py-3 text-sm font-black uppercase tracking-wide text-cream"
          >
            The non-normal footer
          </p>
          <h2
            id="team-footer-title"
            class="max-w-4xl font-serif text-6xl font-semibold leading-[0.9] md:text-8xl lg:text-9xl"
          >
            Put a brilliant person on the pass.
          </h2>
          <div class="mt-9 flex flex-col gap-4 sm:flex-row">
            <a
              class="team-footer-cta team-footer-cta-primary"
              href="mailto:hello@changehospitality.co.uk">Start a brief</a
            >
            <a class="team-footer-cta bg-cream text-ink" href="/portal/"
              >Find work</a
            >
          </div>
        </div>

        <div class="grid gap-6">
          <nav class="team-footer-link-grid" aria-label="Footer navigation">
            {
              footerLinks.map((link, index) => (
                <a
                  class={`team-footer-link team-footer-link-${index + 1}`}
                  href={link.href}
                >
                  <span>{link.label}</span>
                  <small>{link.note}</small>
                </a>
              ))
            }
          </nav>

          <nav class="team-footer-socials" aria-label="Social media">
            {socialLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          </nav>
        </div>
      </div>

      <p class="team-footer-ribbon" aria-hidden="true">
        Front of House / Back of House / Events &amp; Commercial / Twenty years
        of people first recruitment
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ---------- Decorative flat shapes (parallax) ---------- */
  .team-cloud,
  .team-hero-oval,
  .team-section-oval,
  .team-gallery-oval {
    position: absolute;
    pointer-events: none;
    will-change: transform;
    transition: transform 220ms ease-out;
  }

  .team-cloud {
    border-radius: 999px;
    background: var(--color-cream);
  }

  .team-cloud-1 {
    top: 12%;
    left: 4%;
    height: 5rem;
    width: 12rem;
  }

  .team-cloud-2 {
    top: 26%;
    right: 6%;
    height: 4rem;
    width: 9rem;
  }

  .team-hero-oval,
  .team-section-oval,
  .team-gallery-oval {
    border-radius: 999px;
  }

  .team-hero-oval-1 {
    top: 9%;
    right: -15rem;
    height: 24rem;
    width: 38rem;
    background: var(--color-citron);
    transform: rotate(-10deg);
  }

  .team-hero-oval-2 {
    bottom: -9rem;
    left: -16rem;
    height: 26rem;
    width: 42rem;
    background: var(--color-blush);
    transform: rotate(12deg);
  }

  .team-profiles-section {
    background: var(--color-mint);
  }

  .team-pass-section {
    background: var(--color-flame);
  }

  .team-section-oval-one {
    top: -7rem;
    right: -16rem;
    height: 22rem;
    width: 38rem;
    background: var(--color-flame);
    transform: rotate(9deg);
  }

  .team-section-oval-two {
    left: -12rem;
    bottom: 10%;
    height: 18rem;
    width: 30rem;
    background: var(--color-cream);
    transform: rotate(-12deg);
  }

  .team-section-oval-three {
    right: -15rem;
    top: 12%;
    height: 20rem;
    width: 36rem;
    background: var(--color-citron);
    transform: rotate(-8deg);
  }

  .team-gallery-oval {
    top: 12%;
    right: -16rem;
    height: 23rem;
    width: 39rem;
    background: var(--color-flame);
    transform: rotate(-10deg);
  }

  /* ---------- Hero buttons ---------- */
  .team-hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 1.25rem 2.25rem;
    text-align: center;
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-cream);
    transition:
      transform 350ms var(--ease-cartoon),
      background-color 300ms ease;
  }

  .team-hero-button:hover,
  .team-hero-button:focus-visible {
    transform: translateY(-3px) rotate(-1deg);
  }

  /* ---------- Pass stage illustration ---------- */
  .team-pass-stage {
    display: grid;
    place-items: center;
  }

  .team-plate {
    position: relative;
    display: grid;
    height: min(30rem, 74vw);
    width: min(30rem, 74vw);
    place-items: center;
    border-radius: 999px;
    background: var(--color-blush);
    will-change: transform;
    transition: transform 220ms ease-out;
  }

  .team-plate::before {
    position: absolute;
    inset: 9%;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-blush) 45%, var(--color-cream));
    content: "";
  }

  .team-egg-white {
    position: relative;
    z-index: 2;
    height: 48%;
    width: 56%;
    border-radius: 48% 52% 55% 45% / 58% 46% 54% 42%;
    background: var(--color-cream);
    transform: rotate(-8deg);
    animation: team-egg-wobble 5s ease-in-out infinite;
  }

  .team-yolk {
    position: absolute;
    left: 46%;
    top: 47%;
    height: 34%;
    width: 34%;
    border-radius: 999px;
    background: var(--color-citron);
    transform: translate(-50%, -50%);
  }

  .team-plate-note {
    position: absolute;
    z-index: 3;
    bottom: 11%;
    left: 50%;
    width: max-content;
    max-width: 13rem;
    border-radius: 999px;
    background: var(--color-flame);
    color: var(--color-cream);
    padding: 0.55rem 0.9rem;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    transform: translateX(-50%) rotate(-3deg);
  }

  .team-pass-ticket,
  .team-orbit-card {
    position: absolute;
    z-index: 4;
    color: var(--color-ink);
    transform: translate3d(0, 0, 0) rotate(var(--float-rotate, 0deg));
    will-change: transform;
  }

  .team-pass-ticket {
    width: 12rem;
    border-radius: 1.25rem;
    background: var(--color-cream);
    padding: 1rem 1.1rem;
    animation: team-float 6.5s cubic-bezier(0.42, 0, 0.18, 1) infinite;
  }

  .team-pass-ticket span,
  .team-orbit-card span {
    display: block;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .team-pass-ticket strong {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-serif);
    font-size: 1.65rem;
    line-height: 0.9;
  }

  .team-pass-ticket-one {
    --float-rotate: -8deg;
    left: 0;
    top: 8%;
    background: var(--color-citron);
  }

  .team-pass-ticket-two {
    --float-rotate: 7deg;
    right: -2%;
    top: 3%;
    background: var(--color-mint);
    animation-delay: 700ms;
  }

  .team-pass-ticket-three {
    --float-rotate: -3deg;
    bottom: 6%;
    right: 8%;
    background: var(--color-blush);
    animation-delay: 1200ms;
  }

  .team-orbit-card {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 11rem;
    border-radius: 999px;
    background: var(--color-cream);
    padding: 0.5rem 0.75rem;
    animation: team-float 7s cubic-bezier(0.42, 0, 0.18, 1) infinite;
  }

  .team-orbit-card img {
    height: 2.8rem;
    width: 2.8rem;
    border-radius: 999px;
    object-fit: cover;
  }

  .team-orbit-1 {
    --float-rotate: 4deg;
    left: 6%;
    bottom: 20%;
    background: var(--color-mist);
  }

  .team-orbit-2 {
    --float-rotate: -5deg;
    right: 2%;
    top: 32%;
    background: var(--color-citron);
    animation-delay: 500ms;
  }

  .team-orbit-3 {
    --float-rotate: -2deg;
    left: 0;
    top: 44%;
    background: var(--color-blush);
    animation-delay: 900ms;
  }

  .team-orbit-4 {
    --float-rotate: 5deg;
    right: 16%;
    bottom: 2%;
    background: var(--color-mint);
    animation-delay: 1400ms;
  }

  /* ---------- Equal-height profile card grid ---------- */
  .team-card-grid {
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .team-card-grid {
      grid-auto-rows: 1fr;
    }
  }

  :global(.team-card-wrap) {
    perspective: none;
  }

  :global(.team-profile-card) {
    transform: translate3d(
        calc((var(--pointer-from-left, 0.5) - 0.5) * 14px),
        calc((var(--pointer-from-top, 0.5) - 0.5) * 10px),
        0
      )
      rotate(var(--card-tilt, 0deg));
    transition: transform 320ms var(--ease-cartoon);
  }

  :global(.team-card-name) {
    font-size: clamp(2.45rem, 4vw, 3.8rem);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  :global(.team-card-mark),
  :global(.team-card-photo-frame),
  :global(.team-card-info) {
    transform: translate3d(0, 0, 0);
    transition: transform 320ms var(--ease-cartoon);
  }

  :global(.team-card-wrap:hover .team-card-mark),
  :global(.team-card-wrap:focus-within .team-card-mark) {
    transform: translate3d(-0.35rem, 0.2rem, 0) rotate(-8deg);
  }

  :global(.team-card-wrap:hover .team-card-photo-frame),
  :global(.team-card-wrap:focus-within .team-card-photo-frame) {
    transform: rotate(1.5deg) scale(0.98);
  }

  :global(.team-card-wrap:hover .team-card-info),
  :global(.team-card-wrap:focus-within .team-card-info) {
    transform: translateY(-0.3rem) rotate(-0.7deg);
  }

  :global(.team-card-wrap:hover .team-card-blob),
  :global(.team-card-wrap:focus-within .team-card-blob) {
    opacity: 1;
  }

  :global(.team-card-avatar) {
    transform: scale(1.05)
      translate(
        calc((var(--pointer-from-left, 0.5) - 0.5) * 14px),
        calc((var(--pointer-from-top, 0.5) - 0.5) * 10px)
      );
    transition: transform 300ms ease;
  }

  /* ---------- Process step cards ---------- */
  .team-step-card {
    transition:
      transform 260ms var(--ease-cartoon),
      background-color 260ms ease;
  }

  .team-step-card:hover {
    transform: translateY(-4px) rotate(-1deg);
    background: var(--color-citron);
  }

  .team-process-poster {
    clip-path: polygon(0 6%, 96% 0, 100% 88%, 8% 100%);
  }

  .team-step-card:nth-child(2) {
    background: var(--color-mint);
    transform: rotate(1deg);
    transition:
      transform 260ms var(--ease-cartoon),
      background-color 260ms ease;
  }

  .team-step-card:nth-child(3) {
    background: var(--color-citron);
    transform: rotate(-1deg);
    transition:
      transform 260ms var(--ease-cartoon),
      background-color 260ms ease;
  }

  .team-footer {
    background: var(--color-citron);
  }

  .team-footer::before {
    position: absolute;
    inset: 6% auto auto -8%;
    height: 20rem;
    width: 32rem;
    border-radius: 999px;
    background: var(--color-story-blue);
    content: "";
    transform: rotate(-14deg);
  }

  .team-footer::after {
    position: absolute;
    right: -7%;
    bottom: 9%;
    height: 22rem;
    width: 28rem;
    border-radius: 38% 62% 62% 38% / 44% 34% 66% 56%;
    background: var(--color-blush);
    content: "";
    transform: rotate(10deg);
  }

  .team-footer-stamp {
    position: absolute;
    z-index: 1;
    display: grid;
    place-items: center;
    border-radius: 2rem;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 6rem);
    line-height: 1;
    text-transform: uppercase;
    will-change: transform;
  }

  .team-footer-stamp-one {
    top: 10%;
    right: 12%;
    height: 9rem;
    width: 14rem;
    background: var(--color-flame);
    color: var(--color-cream);
    transform: rotate(8deg);
  }

  .team-footer-stamp-two {
    left: 7%;
    bottom: 18%;
    height: 8rem;
    width: 18rem;
    background: var(--color-mint);
    color: var(--color-ink);
    transform: rotate(-7deg);
  }

  .team-footer-egg {
    position: absolute;
    right: 7%;
    top: 38%;
    z-index: 1;
    height: 13rem;
    width: 16rem;
    border-radius: 56% 44% 47% 53% / 58% 45% 55% 42%;
    background: var(--color-cream);
    transform: rotate(-14deg);
    will-change: transform;
  }

  .team-footer-egg span {
    position: absolute;
    inset: 32% auto auto 38%;
    height: 4.6rem;
    width: 4.6rem;
    border-radius: 999px;
    background: var(--color-flame);
  }

  .team-footer-cta {
    position: relative;
    z-index: 12;
    display: inline-flex;
    min-width: 11rem;
    min-height: 4.4rem;
    align-items: center;
