<script>
  function initTeamParallax() {
    const page = document.querySelector<HTMLElement>("[data-team-page]");
    if (!page || page.dataset.parallaxReady === "true") return;
    page.dataset.parallaxReady = "true";

    const items = Array.from(
      page.querySelectorAll<HTMLElement>("[data-parallax]"),
    );
    if (!items.length) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const state = { pointerX: 0, pointerY: 0, scrollY: window.scrollY };
    items.forEach((el) => {
      if (!el.dataset.baseTransform) {
        el.dataset.baseTransform =
          window.getComputedStyle(el).transform === "none"
            ? ""
            : window.getComputedStyle(el).transform;
      }
    });

    let raf = 0;
    const render = () => {
      raf = 0;
      items.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const depth = Number(el.getAttribute("data-parallax") || 0);
        const sectionOffset =
          ((rect.top + rect.height / 2 - window.innerHeight / 2) /
            window.innerHeight) *
          depth *
          -0.42;
        const pointerX = state.pointerX * depth;
        const pointerY = state.pointerY * depth;
        const base = el.dataset.baseTransform || "";
        el.style.transform = `${base} translate3d(${pointerX.toFixed(1)}px, ${(pointerY + sectionOffset).toFixed(1)}px, 0)`;
      });
    };

    const requestRender = () => {
      if (raf) return;
      raf = window.requestAnimationFrame(render);
    };

    const onMove = (event: PointerEvent) => {
      state.pointerX = (event.clientX / window.innerWidth - 0.5) * 2;
      state.pointerY = (event.clientY / window.innerHeight - 0.5) * 2;
      requestRender();
    };

    const onScroll = () => {
      state.scrollY = window.scrollY;
      requestRender();
    };

    window.addEventListener("pointermove", onMove, { passive: true });
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", requestRender, { passive: true });
    requestRender();
  }

  initTeamParallax();
  document.addEventListener("astro:page-load", initTeamParallax);
</script>
