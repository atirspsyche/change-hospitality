---
import ApplicationSection from '../components/ApplicationSection.astro';
import DivisionSplit from '../components/DivisionSplit.astro';
import FinalCTA from '../components/FinalCTA.astro';
import FunMenu from '../components/FunMenu.astro';
import HomeStoryHero from '../components/HomeStoryHero';
import HomeExperience from '../components/HomeExperience.astro';
import ImpactTracker from '../components/ImpactTracker.astro';
import OpportunitiesStream from '../components/OpportunitiesStream.astro';
import PhilosophyReveal from '../components/PhilosophyReveal.astro';
import TestimonialsStack from '../components/TestimonialsStack.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const homeMenuLinks = [
  { label: 'Our approach', href: '#approach', meta: 'People before databases' },
  { label: 'Divisions', href: '#divisions', meta: 'Where we specialise' },
  { label: 'Live jobs', href: '#opportunities', meta: 'Open opportunities' },
  { label: 'Apply', href: '#apply', meta: 'Join the pass' },
  { label: 'Team', href: '/team/', meta: 'Meet the consultants' },
];
---

<BaseLayout>
  <FunMenu links={homeMenuLinks} />
  <main class="home-page bg-cream text-ink">
    <HomeStoryHero client:load />
    <PhilosophyReveal />
    <DivisionSplit />
    <ImpactTracker />
    <OpportunitiesStream />
    <TestimonialsStack />
    <ApplicationSection />
    <FinalCTA />
  </main>
  <HomeExperience />
</BaseLayout>
